# Copy to .env and fill in. .env is gitignored — never commit real keys.

# OpenAI: used by khora for embeddings (text-embedding-3-small) + entity
# extraction (gpt-4o-mini), and by the read-side answer agent.
OPENAI_API_KEY=sk-...

# football-data.org free-tier token (match results, standings, scorers).
# Get one at https://www.football-data.org/client/register
DATA_FOOTBALL_TOKEN=...

# NewsData.io token (best-effort news supplement; free tier = 200 credits/day).
# Get one at https://newsdata.io/
NEWSDATA_TOKEN=...
